# Copy to .env and fill in. Set the same vars in the Vercel project settings.

# GitHub fine-grained PAT (read access) — powers the contributions heatmap + OG numbers
PAT=
# Optional: override the GitHub login (defaults to SirTenzin)
GITHUB_LOGIN=

# Databuddy analytics client id (public — inlined into the client bundle by Vite)
VITE_DATABUDDY_CLIENT_ID=28498450-8138-4f1b-8c99-604cb782cbbf

# Vercel Deploy Hook URL — the daily cron POSTs this to rebuild (refreshes the OG image)
DEPLOY_HOOK_URL=
# Optional: shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=
